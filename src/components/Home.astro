---
// Home hero section component
---

<section id="home" class="view">
  <div class="home-hero">
    <h2 class="home-title">Welcome to 𝚺 Music</h2>
    <p class="home-subtitle">Discover and stream your favorite music</p>
    <div class="home-actions">
      <button id="homeSearchBtn" class="home-button">
        🔍 Start Searching
      </button>
      <button id="homeFavoritesBtn" class="home-button secondary">
        ⭐ View Favorites
      </button>
    </div>
  </div>
</section>

<script>
  import { showView } from "../scripts/ui.js";
  import { openPlaylist } from "../scripts/playlists.js";

  document.getElementById("homeSearchBtn")?.addEventListener("click", () => showView("search"));
  document.getElementById("homeFavoritesBtn")?.addEventListener("click", () => openPlaylist("favorites"));
</script>
